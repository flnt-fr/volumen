---
import '../styles/theme.css';
import NavBar from '../components/site/NavBar.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import LocaleFOUCScript from '../components/site/LocaleFOUCScript.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<title>Volumen — Legal notice</title>
		<meta name="description" content="Legal notice for volumen.flnt.fr" />
	</head>
	<body class="min-h-screen bg-base-200 text-base-content">
		<NavBar
			links={[
				{ href: '/about', key: 'footer.about' },
			]}
			cta={{ href: '/app', key: 'nav.openApp' }}
		/>

		<main class="container mx-auto max-w-3xl px-4 py-8">
			<article class="prose prose-neutral dark:prose-invert max-w-none">
				<h1 data-i18n-key="legal.heading">Legal notice</h1>
				<p data-i18n-key="legal.intro">
					This page is provided as the legal notice ("mentions légales") required under French law
					(LCEN, art. 6-III) for a website published from France.
				</p>

				<h2 data-i18n-key="legal.publisher.heading">Publisher</h2>
				<p data-i18n-key="legal.publisher.body">
					This site is published on a non-professional, personal basis by Florent A.<br />
					Contact: <a href="mailto:volumen@flnt.fr">volumen@flnt.fr</a>
				</p>
				<p data-i18n-key="legal.publisher.director">
					Publication director: Florent A.
				</p>

				<h2 data-i18n-key="legal.hosting.heading">Hosting provider</h2>
				<p data-i18n-key="legal.hosting.body">
					This site is hosted on a virtual private server operated by:<br />
					OVH SAS — capital of €50,000,000<br />
					2 rue Kellermann, 59100 Roubaix, France<br />
					RCS Lille Métropole 424 761 419 00045
				</p>

				<h2 data-i18n-key="legal.ip.heading">Intellectual property</h2>
				<p data-i18n-key="legal.ip.body">
					The application code is released under the MIT license. It bundles third-party data
					under their own, separate terms (an open exercise database released into the public
					domain, and a condensed summary of a copyrighted scientific publication). Full details,
					credits, and license text are available in the project's <a href="https://github.com/flnt-fr/volumen">source repository</a> and its <code>README.md</code>/<code>LICENSE</code> files.
				</p>

				<h2 data-i18n-key="legal.personalData.heading">Personal data</h2>
				<p data-i18n-key="legal.personalData.body">
					Volumen runs entirely in your browser. It has no backend, no user accounts, no
					analytics, and sets no cookies. The training program you build is stored only in your
					browser's <code>localStorage</code> and is never transmitted to, or seen by, the
					publisher or the hosting provider. Clearing your browser's site data removes it
					permanently. Because no personal data is collected or processed by the publisher, no
					data-controller relationship is established and there is nothing to request access to,
					correct, or delete on our end.
				</p>

				<h2 data-i18n-key="legal.liability.heading">Liability</h2>
				<p data-i18n-key="legal.liability.body">
					Volumen is an experimental, hobby project (see the <a href="/about">About</a> page for
					context) provided "as is", without warranty of any kind, and is not medical or
					professional fitness advice. Consult a qualified professional before starting any
					training program.
				</p>
			</article>
		</main>
		<SiteFooter />
		<LocaleFOUCScript />
	</body>
</html>
