---
import { t } from '../../i18n/t';
import type { TranslationKey } from '../../i18n/strings.en';
import { DEFAULT_LOCALE } from '../../i18n/types';
import LocaleSelect from './LocaleSelect';

export interface NavLink {
  href: string;
  /** i18n key for the link's label. */
  key: TranslationKey;
}

interface Props {
  /** Secondary text links shown before the CTA (or as the only links, if no CTA). */
  links: NavLink[];
  /** Optional primary call-to-action rendered as a filled button. */
  cta?: NavLink;
}

const { links, cta } = Astro.props;

/**
 * The single header used on every route (/, /about, /legal, /404, and /app
 * via AppHeader.tsx). The logo, nav links, and optional CTA are static
 * markup — translated in place by applyStaticLocale() via `data-i18n-key`,
 * same as the rest of each static page's content — so only the locale
 * `<select>` (LocaleSelect, a genuinely interactive leaf) is hydrated as a
 * Preact island, per Astro's islands model. /app can't use this component
 * directly (it's already inside a hydrated Preact tree with its own
 * Context-based i18n), so AppHeader.tsx mirrors this markup/classes/link set
 * instead — keep the two in sync if you change one.
 */
---

<header class="navbar flex-wrap gap-x-2 gap-y-1 bg-base-100 shadow-sm px-4 py-2 sm:px-6">
	<div class="flex-1">
		<a href="/" class="btn btn-ghost text-xl">Volumen</a>
	</div>
	<div class="flex-none max-w-full">
		<ul class="menu menu-horizontal max-w-full flex-wrap items-center justify-end gap-1 px-1">
			{links.map((link) => (
				<li><a href={link.href} data-i18n-key={link.key}>{t(DEFAULT_LOCALE, link.key)}</a></li>
			))}
			{cta && (
				<li>
					<a href={cta.href} class="btn btn-primary btn-sm ml-1" data-i18n-key={cta.key}>{t(DEFAULT_LOCALE, cta.key)}</a>
				</li>
			)}
			<li>
				<!--
					daisyUI's .menu CSS forces `display: grid` on any direct <li>
					child that isn't ul/menu/details/.menu-title/.btn — and unlike
					its footer rule, it doesn't exclude script/style tags. Astro's
					client:load hydration injects a <style>+<script> pair as
					siblings of <astro-island>, so without this wrapper div they'd
					land as direct <li> children too and get forced into the grid,
					turning their raw JS/CSS text into a visible, absurdly wide grid
					item. The wrapper keeps them one level down, outside the `li > *`
					selector; astro-island's own `display: contents` still lets
					LocaleSelect's label/select participate directly in this div's
					grid layout, so the visual result is unaffected.
				-->
				<div class="inline-flex items-center p-0">
					<LocaleSelect client:load />
				</div>
			</li>
		</ul>
	</div>
</header>
